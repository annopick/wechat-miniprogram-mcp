{"knowledge_relations":[{"id":1,"source_id":"ffe8347c-7e2b-40af-9cc5-d58fc30ed865","target_id":"d7b70e09-33f3-4c74-abdc-9e250943ec2c","source_type":"WIKI_ITEM","target_type":"WIKI_ITEM","relationship_type":"PARENT_CHILD","extra":"Wiki parent-child relationship: ffe8347c-7e2b-40af-9cc5-d58fc30ed865 -\u003e d7b70e09-33f3-4c74-abdc-9e250943ec2c","gmt_create":"2026-06-03T21:37:02.139512+08:00","gmt_modified":"2026-06-03T21:37:02.139512+08:00"},{"id":2,"source_id":"ffe8347c-7e2b-40af-9cc5-d58fc30ed865","target_id":"75dd6939-4d0c-4369-85db-2418f26a26a3","source_type":"WIKI_ITEM","target_type":"WIKI_ITEM","relationship_type":"PARENT_CHILD","extra":"Wiki parent-child relationship: ffe8347c-7e2b-40af-9cc5-d58fc30ed865 -\u003e 75dd6939-4d0c-4369-85db-2418f26a26a3","gmt_create":"2026-06-03T21:37:02.143336+08:00","gmt_modified":"2026-06-03T21:37:02.143336+08:00"}],"wiki_catalogs":[{"id":"ace788ca-35cd-4a73-809a-084668652222","repo_id":"f318a77a-d64a-4cee-b8d4-77afe8e125ab","name":"快速开始","description":"getting-started","prompt":"为微信小程序MCP项目创建全面的快速开始指南。详细说明安装步骤、环境配置要求、基本使用方法。包含环境变量配置说明（WECHAT_DEVTOOLS_PORT、WECHAT_DEVTOOLS_CLI_PATH、WECHAT_PROJECT_PATH、LOG_LEVEL），微信开发者工具设置步骤，以及MCP客户端配置示例。提供完整的安装命令、配置示例和基本使用流程，确保新用户能够快速上手项目。","progress_status":"completed","dependent_files":"README.md,package.json","gmt_create":"2026-06-03T21:33:18.635981+08:00","gmt_modified":"2026-06-03T21:34:12.139412+08:00","raw_data":"WikiEncrypted:"},{"id":"d0dacc57-359a-4dcd-b8fa-350e4758759d","repo_id":"f318a77a-d64a-4cee-b8d4-77afe8e125ab","name":"控制API","description":"control-api","prompt":"创建控制API的详细文档，涵盖所有wechat_control_*系列接口。详细说明初始化配置（initControlApi）、默认项目获取（getDefaultProject）、通用调用函数（callControlApi）的功能和使用方法。记录每个API的参数类型、返回值结构、错误处理机制。包含HTTP方法支持、URL构建规则、超时配置、内容类型检测等技术细节。提供实际的调用示例，展示如何正确配置端口、设置超时时间、处理不同类型的响应数据（文本、JSON、二进制）。说明与微信开发者工具的交互协议和最佳实践。","parent_id":"7cb90d2b-3f99-44b3-bb2e-e84ebdc5fea9","progress_status":"completed","dependent_files":"src/api/control.ts","gmt_create":"2026-06-03T21:33:24.450908+08:0